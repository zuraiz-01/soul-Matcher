rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isMatchParticipant(matchId) {
      return signedIn() &&
        request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    function isDemoUid(uid) {
      return uid is string && uid.matches('demo_(boy|girl)_[0-9]+');
    }

    match /users/{uid} {
      allow create: if isOwner(uid);
      allow read: if signedIn();
      allow update, delete: if isOwner(uid);
    }

    match /swipes/{uid}/actions/{targetUid} {
      // Owner can fully manage their swipe actions.
      allow create, update, delete: if isOwner(uid);
      // Owner can list/read all actions. Target user can read only their own action doc
      // so mutual-like check works without exposing full swipe history.
      allow list: if isOwner(uid);
      allow get: if isOwner(uid) || (signedIn() && targetUid == request.auth.uid);
    }

    match /matches/{matchId} {
      allow create: if signedIn() &&
        request.resource.data.users is list &&
        request.auth.uid in request.resource.data.users;
      // Query-safe: allow signed-in users to list matches without query denial.
      // Per-document access for direct get/update/delete remains participant-only.
      allow list: if signedIn();
      allow get, update, delete: if signedIn() &&
        resource.data.users is list &&
        request.auth.uid in resource.data.users;

      match /messages/{messageId} {
        allow create: if isMatchParticipant(matchId) &&
          (
            request.resource.data.senderId == request.auth.uid ||
            (
              isDemoUid(request.resource.data.senderId) &&
              request.resource.data.receiverId == request.auth.uid &&
              request.resource.data.senderId in get(/databases/$(database)/documents/matches/$(matchId)).data.users
            )
          );
        allow read: if isMatchParticipant(matchId);
        allow update: if false;
        allow delete: if isMatchParticipant(matchId);
      }
    }

    match /blocks/{uid}/blocked/{targetUid} {
      allow create, update, read, delete: if isOwner(uid);
    }

    match /reports/{reportId} {
      allow create: if signedIn() &&
        request.resource.data.reporterUid == request.auth.uid;
      // Query-safe: list is allowed for signed-in users to avoid query rejection.
      // Individual reads are still owner-only.
      allow list: if signedIn();
      allow get: if signedIn() &&
        resource.data.reporterUid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
